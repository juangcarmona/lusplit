---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LANGS, getUiStrings } from '../../lib/i18n';
import type { Lang } from '../../lib/i18n';

export const getStaticPaths: GetStaticPaths = () => {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const ui = getUiStrings(lang);

const pageTitles: Record<Lang, string> = {
  en: 'Screenshots — LuSplit',
  es: 'Capturas de pantalla — LuSplit',
  fr: "Captures d'écran — LuSplit",
  de: 'Screenshots — LuSplit',
  pt: 'Capturas de ecrã — LuSplit',
  it: 'Schermate — LuSplit',
};

const pageDescriptions: Record<Lang, string> = {
  en: 'Real screenshots from LuSplit showing the core flow: overview, expenses, add expense, settlement, payments, and group setup.',
  es: 'Capturas reales de LuSplit mostrando el flujo principal: visión general, gastos, añadir gasto, liquidación, pagos y creación de grupo.',
  fr: "Vraies captures d'écran de LuSplit montrant le flux principal : vue d'ensemble, dépenses, ajout d'une dépense, règlement, paiements et création de groupe.",
  de: 'Echte Screenshots von LuSplit mit dem Kernablauf: Übersicht, Ausgaben, Ausgabe hinzufügen, Abrechnung, Zahlungen und Gruppenerstellung.',
  pt: 'Capturas reais do LuSplit a mostrar o fluxo principal: visão geral, despesas, adicionar despesa, liquidação, pagamentos e criação de grupo.',
  it: 'Screenshot reali di LuSplit che mostrano il flusso principale: panoramica, spese, aggiunta spesa, saldo, pagamenti e creazione gruppo.',
};

const headings: Record<Lang, string> = {
  en: 'Screenshots',
  es: 'Capturas de pantalla',
  fr: "Captures d'écran",
  de: 'Screenshots',
  pt: 'Capturas de ecrã',
  it: 'Schermate',
};

const intros: Record<Lang, string> = {
  en: 'A real look at LuSplit across the core product flow: setup, tracking expenses, understanding balances, and settling up.',
  es: 'Una visión real de LuSplit a través del flujo principal del producto: configuración, registro de gastos, comprensión de saldos y liquidación.',
  fr: "Un aperçu réel de LuSplit à travers le flux principal du produit : configuration, suivi des dépenses, compréhension des soldes et règlement.",
  de: 'Ein echter Blick auf LuSplit entlang des zentralen Produktablaufs: Einrichtung, Ausgaben erfassen, Salden verstehen und abrechnen.',
  pt: 'Uma visão real do LuSplit ao longo do fluxo principal do produto: configuração, registo de despesas, compreensão de saldos e liquidação.',
  it: 'Uno sguardo reale a LuSplit lungo il flusso principale del prodotto: configurazione, registrazione spese, comprensione dei saldi e saldo finale.',
};

const screenshotCaptions: Record<string, Record<Lang, string>> = {
  group_overview: {
    en: 'Overview — balances and recent activity at a glance',
    es: 'Resumen — saldos y actividad reciente de un vistazo',
    fr: "Vue d'ensemble — soldes et activité récente en un coup d'œil",
    de: 'Übersicht — Salden und letzte Aktivität auf einen Blick',
    pt: 'Visão geral — saldos e atividade recente num relance',
    it: "Panoramica — saldi e attività recente a colpo d'occhio",
  },
  group_expenses: {
    en: 'Expenses — every shared expense in one list',
    es: 'Gastos — todos los gastos compartidos en una sola lista',
    fr: 'Dépenses — toutes les dépenses partagées dans une seule liste',
    de: 'Ausgaben — alle geteilten Ausgaben in einer Liste',
    pt: 'Despesas — todas as despesas partilhadas numa só lista',
    it: 'Spese — tutte le spese condivise in un unico elenco',
  },
  add_expense: {
    en: 'Add expense — title, amount, participants, and instant impact preview',
    es: 'Añadir gasto — título, importe, participantes y vista previa inmediata del impacto',
    fr: "Ajouter une dépense — titre, montant, participants et aperçu immédiat de l'impact",
    de: 'Ausgabe hinzufügen — Titel, Betrag, Teilnehmer und sofortige Auswirkungsvorschau',
    pt: 'Adicionar despesa — título, valor, participantes e pré-visualização imediata do impacto',
    it: "Aggiungi spesa — titolo, importo, partecipanti e anteprima immediata dell'impatto",
  },
  settle_up: {
    en: 'Settle up — the minimum transfers needed to clear debts',
    es: 'Liquidar — las transferencias mínimas necesarias para saldar deudas',
    fr: 'Régler — les virements minimaux nécessaires pour solder les dettes',
    de: 'Abrechnen — die minimal nötigen Überweisungen zum Begleichen der Schulden',
    pt: 'Liquidar — as transferências mínimas necessárias para acertar as dívidas',
    it: 'Pareggia i conti — i trasferimenti minimi necessari per chiudere i debiti',
  },
  record_payment: {
    en: 'Record payment — save a suggested payment directly',
    es: 'Registrar pago — guarda directamente un pago sugerido',
    fr: 'Enregistrer un paiement — enregistrez directement un paiement suggéré',
    de: 'Zahlung erfassen — eine vorgeschlagene Zahlung direkt speichern',
    pt: 'Registar pagamento — guardar diretamente um pagamento sugerido',
    it: 'Registra pagamento — salva direttamente un pagamento suggerito',
  },
  create_group_people: {
    en: 'Create group — add people and define who depends on whom',
    es: 'Crear grupo — añade personas y define quién depende de quién',
    fr: 'Créer un groupe — ajoutez des personnes et définissez qui dépend de qui',
    de: 'Gruppe erstellen — Personen hinzufügen und Abhängigkeiten festlegen',
    pt: 'Criar grupo — adicionar pessoas e definir quem depende de quem',
    it: 'Crea gruppo — aggiungi persone e definisci chi dipende da chi',
  },
};

const screenshots = [
  'group_overview',
  'group_expenses',
  'add_expense',
  'settle_up',
  'record_payment',
  'create_group_people',
];

const pageTitle = pageTitles[lang];
const pageDescription = pageDescriptions[lang];
const heading = headings[lang];
const intro = intros[lang];
---

<BaseLayout lang={lang} title={pageTitle} description={pageDescription} ui={ui}>
  <section class="screenshots-page section">
    <div class="container">
      <header class="screenshots-header">
        <h1 class="screenshots-title">{heading}</h1>
        <p class="screenshots-intro">{intro}</p>
      </header>

      <div class="screenshots-grid">
        {screenshots.map((name, index) => (
          <figure class={`screenshot-card ${index === 0 ? 'featured' : ''}`}>
            <div class="screenshot-img-wrap">
              <img
                src={`/screenshots/${name}.png`}
                alt={screenshotCaptions[name][lang]}
                loading={index === 0 ? 'eager' : 'lazy'}
                class="screenshot-img"
              />
            </div>
            <figcaption class="screenshot-caption">
              {screenshotCaptions[name][lang]}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .screenshots-page {
    min-height: 60vh;
  }

  .screenshots-header {
    margin-bottom: 2.5rem;
    max-width: 52rem;
  }

  .screenshots-title {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .screenshots-intro {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 60ch;
    line-height: 1.7;
  }

  .screenshots-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: start;
  }

  .screenshot-card {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .screenshot-card.featured {
    grid-column: 1 / -1;
  }

  .screenshot-card.featured .screenshot-img-wrap {
    max-width: 420px;
  }

.screenshot-img-wrap {
  max-width: 320px;        /* phone width */
  margin: 0 auto;
  border-radius: 32px;     /* device corners */
  padding: 10px;           /* frame thickness */
  background: #0f0f10;     /* phone body */
  box-shadow: 
    0 10px 30px rgba(0,0,0,0.4),
    inset 0 0 0 2px #1c1c1e;
}

.screenshot-img-wrap::before {
  content: '';
  display: block;
  width: 80px;
  height: 6px;
  background: #2a2a2d;
  border-radius: 3px;
  margin: 0 auto 8px auto; /* speaker */
}

.screenshot-img {
  border-radius: 24px;     /* screen corners */
}

  .screenshot-caption {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.45;
    padding-inline: 0.15rem;
  }

  @media (max-width: 900px) {
    .screenshots-grid {
      grid-template-columns: 1fr;
    }

    .screenshot-card.featured {
      grid-column: auto;
    }
  }
</style>