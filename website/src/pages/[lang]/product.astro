---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUPPORTED_LANGS, getUiStrings } from '../../lib/i18n';
import type { Lang } from '../../lib/i18n';

export const getStaticPaths: GetStaticPaths = () => {
  return SUPPORTED_LANGS.map(lang => ({ params: { lang } }));
};

const { lang } = Astro.params as { lang: Lang };
const ui = getUiStrings(lang);

const steps = [
  {
    titleKey: 'product.step1.title',
    descKey:  'product.step1.desc',
    bullets:  ['product.step1.b1', 'product.step1.b2', 'product.step1.b3'],
    img:      '/screenshots/create_group_people.png',
    imgAlt:   'Create group — add people and define who depends on whom',
  },
  {
    titleKey: 'product.step2.title',
    descKey:  'product.step2.desc',
    bullets:  ['product.step2.b1', 'product.step2.b2', 'product.step2.b3'],
    img:      '/screenshots/add_expense.png',
    imgAlt:   'Add expense — title, amount, participants, and instant impact preview',
  },
  {
    titleKey: 'product.step3.title',
    descKey:  'product.step3.desc',
    bullets:  ['product.step3.b1', 'product.step3.b2', 'product.step3.b3'],
    img:      '/screenshots/group_overview.png',
    imgAlt:   'Overview — balances and recent activity at a glance',
  },
  {
    titleKey: 'product.step4.title',
    descKey:  'product.step4.desc',
    bullets:  ['product.step4.b1', 'product.step4.b2', 'product.step4.b3'],
    img:      '/screenshots/group_expenses.png',
    imgAlt:   'Expenses — every shared expense in one list',
  },
  {
    titleKey: 'product.step5.title',
    descKey:  'product.step5.desc',
    bullets:  ['product.step5.b1', 'product.step5.b2', 'product.step5.b3'],
    img:      '/screenshots/settle_up.png',
    imgAlt:   'Settle up — the minimum transfers needed to clear debts',
  },
  {
    titleKey: 'product.step6.title',
    descKey:  'product.step6.desc',
    bullets:  ['product.step6.b1', 'product.step6.b2', 'product.step6.b3'],
    img:      '/screenshots/record_payment.png',
    imgAlt:   'Record payment — save a suggested payment directly',
  },
];
---

<BaseLayout
  lang={lang}
  title={ui['product.title'] ?? 'How it Works'}
  description={ui['product.subtitle'] ?? "From setting up a group to settling up — here's exactly how it works."}
  ui={ui}
>
  <section class="product-page section">
    <div class="container">

      <header class="product-hero">
        <h1 class="product-title">{ui['product.title']}</h1>
        <p class="product-subtitle">{ui['product.subtitle']}</p>
      </header>

      <div class="steps-grid">
        {steps.map((step, i) => (
          <article class="step-card">
            <div class="step-card__body">
              <span class="step-label">{ui['product.stepLabel']} {i + 1}</span>
              <h2 class="step-title">{ui[step.titleKey]}</h2>
              <p class="step-desc">{ui[step.descKey]}</p>
              <ul class="step-bullets">
                {step.bullets.map(bKey => (
                  <li>{ui[bKey]}</li>
                ))}
              </ul>
            </div>
            <div class="step-card__media">
              <div class="phone-shot">
                <img
                  src={step.img}
                  alt={step.imgAlt}
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  /* ─── Page shell ─────────────────────────────────────────── */
  .product-page {
    padding-bottom: 3rem;
  }

  /* ─── Hero ───────────────────────────────────────────────── */
  .product-hero {
    text-align: center;
    max-width: 44rem;
    margin: 0 auto 2rem;
  }

  .product-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .product-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ─── Steps grid (2 × 3 on desktop) ─────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  /* ─── Step card ──────────────────────────────────────────── */
  .step-card {
    background: var(--surface-card, rgba(128, 128, 128, 0.04));
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
    display: grid;
    grid-template-columns: 1fr 196px;
    gap: 1.25rem;
    align-items: center;
  }

  /* ─── Card body ──────────────────────────────────────────── */
  .step-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-teal, #00b4b4);
    margin-bottom: 0.3rem;
  }

  .step-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0 0 0.625rem;
  }

  .step-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-bullets li {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding-left: 1.125rem;
    position: relative;
    line-height: 1.45;
  }

  .step-bullets li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-teal, #00b4b4);
    font-size: 0.75rem;
    top: 0.05em;
  }

  /* ─── Card media / phone frame ───────────────────────────── */
  .step-card__media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .phone-shot {
    background: #111;
    border-radius: 22px;
    padding: 10px 7px 7px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.22);
    width: 100%;
    max-width: 196px;
  }

  .phone-shot::before {
    content: '';
    display: block;
    width: 36px;
    height: 4px;
    background: #2a2a2a;
    border-radius: 2px;
    margin: 0 auto 8px;
  }

  .phone-shot img {
    display: block;
    width: 100%;
    border-radius: 14px;
  }

  /* ─── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .step-card {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .phone-shot {
      max-width: 170px;
      margin: 0 auto;
    }
  }
</style>
