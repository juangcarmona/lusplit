---
interface Props {
  ui: Record<string, string>;
  playHref: string;
  email?: string;
  accent?: 'teal' | 'indigo';
}

const {
  ui,
  playHref,
  email = 'juan@jgcarmona.com',
  accent = 'teal',
} = Astro.props;

const subject = encodeURIComponent(ui['beta.emailSubject']);
const body = encodeURIComponent(ui['beta.emailBody'] ?? '');
const mailtoHref = `mailto:${email}?subject=${subject}${body ? `&body=${body}` : ''}`;
---

<section class={`beta-cta section--tight beta-cta--${accent}`}>
  <div class="container beta-cta__inner">
    <div class="beta-cta__text">
      <h2 class="beta-cta__headline">{ui['beta.headline']}</h2>
      <p class="beta-cta__subtext">{ui['beta.subtext']}</p>
    </div>

    <div class="beta-cta__actions">
      <a
        href={playHref}
        class="btn btn--primary beta-cta__btn beta-cta__btn--play"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={ui['beta.playButton']}
      >
        <img src="/play.svg" alt="" class="beta-cta__play-icon" />
        <span>{ui['beta.playButton']}</span>
      </a>

      <a
        href={mailtoHref}
        class="btn btn--secondary beta-cta__btn"
      >
        {ui['beta.joinButton']}
      </a>
    </div>
  </div>
</section>

<style>
  .beta-cta {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .beta-cta--teal {
    background: var(--bg-teal-soft);
  }

  .beta-cta--indigo {
    background: var(--bg-indigo-soft);
  }

  .beta-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .beta-cta__text {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    max-width: 44rem;
  }

  .beta-cta__headline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: var(--text-primary);
  }

  .beta-cta__subtext {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0;
  }

  .beta-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }

  .beta-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    white-space: nowrap;
  }

  .beta-cta__play-icon {
    width: 1.1rem;
    height: 1.1rem;
    display: block;
    flex: 0 0 auto;
  }

  @media (max-width: 640px) {
    .beta-cta__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .beta-cta__actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .beta-cta__btn {
      width: 100%;
    }
  }
</style>