---
import type { Lang, UiStrings } from "../lib/i18n";
import { localizedHref } from "../lib/i18n";

interface Props {
  lang: Lang;
  ui: UiStrings;
}

const { lang, ui } = Astro.props;

const footerLinks = [
  { key: "nav.home", href: localizedHref(lang, "/") },
  { key: "nav.features", href: localizedHref(lang, "/features") },
  { key: "nav.howItWorks", href: localizedHref(lang, "/how-it-works") },
  { key: "nav.screenshots", href: localizedHref(lang, "/screenshots") },
  { key: "nav.privacy", href: localizedHref(lang, "/privacy") },
  { key: "nav.support", href: localizedHref(lang, "/support") },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a
        href={localizedHref(lang, "/")}
        class="footer-logo-link"
        aria-label="LuSplit home"
      >
        <img src="/lusplit-logo.svg" alt="LuSplit" width="28" height="28" />
      </a>

      <div class="footer-text">
        <span class="footer-tagline">{ui["footer.tagline"]}</span>
        <span class="footer-meta">
          <a
            href="https://github.com/juangcarmona/lusplit"
            target="_blank"
            rel="noopener"
          >
            Open-source
          </a>
          <span>·</span>
          <span>Free forever</span>
        </span>
      </div>
    </div>

    <nav aria-label="Footer navigation">
      <ul class="footer-nav">
        {
          footerLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                {ui[link.key] ?? link.key}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>

<style>
 .site-footer {
  border-top: 1px solid var(--border);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  padding-block: 1.5rem;
  flex-wrap: wrap;
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.footer-text {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.footer-tagline {
  font-size: 0.85rem;
  color: var(--text-muted);
}

.footer-meta {
  font-size: 0.75rem;
  color: var(--text-muted);
  display: flex;
  gap: 0.35rem;
  align-items: center;
}

.footer-meta a {
  color: var(--text-muted);
  text-decoration: none;
}

.footer-meta a:hover {
  color: var(--accent-teal);
}

.footer-nav {
  display: flex;
  gap: 0.75rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.footer-link {
  font-size: 0.85rem;
  color: var(--text-muted);
  text-decoration: none;
}

.footer-link:hover {
  color: var(--accent-teal);
}
</style>
