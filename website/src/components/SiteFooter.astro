---
import type { Lang, UiStrings } from '../lib/i18n';
import { localizedHref } from '../lib/i18n';

interface Props {
  lang: Lang;
  ui: UiStrings;
}

const { lang, ui } = Astro.props;

const footerLinks = [
  { key: 'nav.home',       href: localizedHref(lang, '/') },
  { key: 'nav.features',   href: localizedHref(lang, '/features') },
  { key: 'nav.howItWorks', href: localizedHref(lang, '/how-it-works') },
  { key: 'nav.privacy',    href: localizedHref(lang, '/privacy') },
  { key: 'nav.support',    href: localizedHref(lang, '/support') },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href={localizedHref(lang, '/')} class="footer-logo-link" aria-label="LuSplit home">
        <img src="/lusplit-logo.svg" alt="LuSplit" width="28" height="28" class="footer-logo-img" />
        <span class="footer-wordmark">LuSplit</span>
      </a>
      <p class="footer-tagline">{ui['footer.tagline']}</p>
    </div>

    <nav aria-label="Footer navigation">
      <ul class="footer-nav">
        {footerLinks.map(link => (
          <li>
            <a href={link.href} class="footer-link">{ui[link.key] ?? link.key}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p class="footer-copy">
        {ui['footer.copyright']}
        <span style="margin-left:0.5em;">&bull;</span>
        <span style="margin-left:0.5em;">Made with
          <span style="color:#F59E0B;vertical-align:middle;" aria-label="love" title="love">&#x2764;&#xFE0F;</span>
          by <a href="https://jgcarmona.com" target="_blank" rel="noopener" style="color:var(--accent-teal);font-weight:600;">Juan G Carmona</a>
        </span>
        <span style="margin-left:0.5em;">
          <a href="https://github.com/juangcarmona" target="_blank" rel="noopener" aria-label="GitHub" style="color:var(--accent-indigo);vertical-align:middle;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.5 2.87 8.31 6.84 9.66.5.09.68-.22.68-.48v-1.7c-2.78.61-3.37-1.36-3.37-1.36-.45-1.18-1.1-1.5-1.1-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.65.35-1.11.63-1.37-2.22-.26-4.56-1.13-4.56-5 0-1.1.37-2 .98-2.7-.1-.25-.43-1.28.09-2.67 0 0 .82-.27 2.7 1.03A9.2 9.2 0 0 1 12 7.5c.83.004 1.67.11 2.45.32 1.88-1.3 2.7-1.03 2.7-1.03.52 1.39.19 2.42.09 2.67.61.7.98 1.6.98 2.7 0 3.88-2.34 4.74-4.57 5 .36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10.01 10.01 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"></path></svg>
          </a>
        </span>
        <span style="margin-left:0.5em;">
          <a href="https://github.com/juangcarmona/lusplit" target="_blank" rel="noopener" aria-label="LuSplit GitHub repo" style="color:var(--accent-teal);vertical-align:middle;font-weight:600;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:middle;"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.5 2.87 8.31 6.84 9.66.5.09.68-.22.68-.48v-1.7c-2.78.61-3.37-1.36-3.37-1.36-.45-1.18-1.1-1.5-1.1-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.65.35-1.11.63-1.37-2.22-.26-4.56-1.13-4.56-5 0-1.1.37-2 .98-2.7-.1-.25-.43-1.28.09-2.67 0 0 .82-.27 2.7 1.03A9.2 9.2 0 0 1 12 7.5c.83.004 1.67.11 2.45.32 1.88-1.3 2.7-1.03 2.7-1.03.52 1.39.19 2.42.09 2.67.61.7.98 1.6.98 2.7 0 3.88-2.34 4.74-4.57 5 .36.31.68.92.68 1.86v2.76c0 .27.18.58.69.48A10.01 10.01 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"></path></svg>
            <span style="margin-left:0.25em;">Project Repo</span>
          </a>
        </span>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 2.5rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    width: fit-content;
  }

  .footer-logo-img {
    border-radius: 6px;
  }

  .footer-wordmark {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--text-muted);
    max-width: 30ch;
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color var(--duration-fast) var(--ease-default);
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .footer-link:hover {
    color: var(--accent-teal);
    text-decoration: none;
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-block: 1rem;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
</style>
