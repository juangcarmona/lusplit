---
interface Props {
  headline: string;
  subtext?: string;
  buttonLabel: string;
  buttonHref: string;
  accent?: 'teal' | 'indigo';
}

const { headline, subtext, buttonLabel, buttonHref, accent = 'teal' } = Astro.props;
---

<section class={`cta-block section--tight cta-block--${accent}`}>
  <div class="container cta-inner">
    <div class="cta-text">
      <h2 class="cta-headline">{headline}</h2>
      {subtext && <p class="cta-subtext">{subtext}</p>}
    </div>
    <a href={buttonHref} class={`btn btn--primary cta-btn`}>{buttonLabel}</a>
  </div>
</section>

<style>
  .cta-block {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .cta-block--teal {
    background: var(--bg-teal-soft);
  }

  .cta-block--indigo {
    background: var(--bg-indigo-soft);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .cta-headline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: var(--text-primary);
  }

  .cta-subtext {
    font-size: 0.9375rem;
    color: var(--text-muted);
    max-width: none;
  }

  @media (max-width: 640px) {
    .cta-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
