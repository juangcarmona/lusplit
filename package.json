{
  "name": "lusplit",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:coverage": "NODE_V8_COVERAGE=.coverage turbo test:coverage",
    "typecheck": "turbo typecheck"
  },
  "engines": {
    "node": ">=24.13.1 <25"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
