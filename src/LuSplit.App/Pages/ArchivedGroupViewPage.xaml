<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.ArchivedGroupViewPage"
             Title="{Binding GroupName}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static loc:AppResources.GroupDetails_ExportButton}" Clicked="OnExportClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Spacing="12">

                <!-- Hero header -->
                <Grid HeightRequest="220">

                    <!-- fallback gradient -->
                    <Grid IsVisible="{Binding HasNoGroupImage}">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2CB1A1" Offset="0" />
                                <GradientStop Color="#5A74FF" Offset="1" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <!-- background image -->
                    <Image Source="{Binding GroupImageSource}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasGroupImage}" />

                    <!-- readability overlay -->
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#55000000" Offset="0.0" />
                                <GradientStop Color="#88000000" Offset="0.35" />
                                <GradientStop Color="#DD000000" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <!-- centered content -->
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Padding="24,16,24,24"
                                         Spacing="8">

                        <Border WidthRequest="76"
                                HeightRequest="76"
                                StrokeShape="RoundRectangle 38"
                                Stroke="#55FFFFFF"
                                StrokeThickness="1"
                                BackgroundColor="#22FFFFFF"
                                HorizontalOptions="Center"
                                StrokeLineJoin="Round">
                            <Grid>
                                <Image Source="{Binding GroupImageSource}"
                                       Aspect="AspectFill"
                                       IsVisible="{Binding HasGroupImage}" />
                                <Label Text="🏔️"
                                       FontSize="30"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding HasNoGroupImage}" />
                            </Grid>
                        </Border>

                        <Label Text="{Binding GroupName}"
                               TextColor="White"
                               FontFamily="BrandSemiBold"
                               FontSize="22"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="2" />

                        <Label Text="{Binding GroupMetaText}"
                               TextColor="#E6FFFFFF"
                               FontFamily="BrandRegular"
                               FontSize="13"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Archived status banner (always visible on this page) -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Margin="16,0,16,0"
                        Padding="12,8">
                    <Label Text="{x:Static loc:AppResources.GroupDetails_ArchivedStatus}"
                           Style="{StaticResource BodyMuted}"
                           HorizontalTextAlignment="Center" />
                </Border>

                <!-- tabs -->
                <Grid Padding="16,0,16,0"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Button x:Name="OverviewTabButton"
                            Grid.Column="0"
                            Text="{x:Static loc:AppResources.Group_TabOverview}"
                            Clicked="OnOverviewTabClicked" />
                    <Button x:Name="ExpensesTabButton"
                            Grid.Column="1"
                            Text="{x:Static loc:AppResources.Group_TabExpenses}"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnExpensesTabClicked" />
                    <Button x:Name="BalancesTabButton"
                            Grid.Column="2"
                            Text="{x:Static loc:AppResources.Group_TabBalances}"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnBalancesTabClicked" />
                </Grid>

                <!-- Overview tab -->
                <VerticalStackLayout Padding="16,4,16,8"
                                     IsVisible="{Binding ShowOverview}"
                                     Spacing="10">

                    <VerticalStackLayout IsVisible="{Binding ShowOverviewEmptyState}" Spacing="2">
                        <Label Text="{x:Static loc:AppResources.Home_OverviewNoActivityCount}" Style="{StaticResource BodyMuted}" />
                        <Label Text="{x:Static loc:AppResources.Home_OverviewNoActivityText}" Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>

                    <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}"
                           Style="{StaticResource SectionTitle}"
                           IsVisible="{Binding ShowWhoOwesWhatSection}" />

                    <CollectionView ItemsSource="{Binding WhoOwesWho}"
                                    SelectionMode="None"
                                    IsVisible="{Binding ShowWhoOwesWhatSection}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                    <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static loc:AppResources.Group_TabBalances}"
                           Style="{StaticResource SectionTitle}"
                           IsVisible="{Binding ShowBalancesSection}" />

                    <CollectionView ItemsSource="{Binding Balances}"
                                    SelectionMode="None"
                                    IsVisible="{Binding ShowBalancesSection}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPositive}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource PositiveSoftGreen}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPositive}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource ErrorSoftRed}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static loc:AppResources.Home_RecentExpenses}"
                           Style="{StaticResource SectionTitle}"
                           IsVisible="{Binding HasEvents}" />

                    <CollectionView ItemsSource="{Binding RecentEvents}"
                                    SelectionMode="Single"
                                    Margin="0,6,0,0"
                                    SelectionChanged="OnEventSelectionChanged"
                                    IsVisible="{Binding HasEvents}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                    <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="{Binding Line1}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding Line2}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Expenses tab -->
                <VerticalStackLayout Padding="16,4,16,8"
                                     IsVisible="{Binding ShowExpenses}"
                                     Spacing="10">
                    <Label Text="{x:Static loc:AppResources.Group_TabExpenses}" Style="{StaticResource SectionTitle}" IsVisible="{Binding HasEvents}" />

                    <CollectionView ItemsSource="{Binding Events}"
                                    SelectionMode="Single"
                                    Margin="0,2,0,0"
                                    SelectionChanged="OnEventSelectionChanged"
                                    IsVisible="{Binding HasEvents}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                    <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="{Binding Line1}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding Line2}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="›" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static loc:AppResources.Home_ExpensesEmpty}"
                           Style="{StaticResource BodyMuted}"
                           IsVisible="{Binding ShowExpensesEmptyState}" />
                </VerticalStackLayout>

                <!-- Balances tab -->
                <VerticalStackLayout Padding="16,4,16,8"
                                     IsVisible="{Binding ShowBalances}"
                                     Spacing="10">
                    <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowWhoOwesWhatSection}" />

                    <CollectionView ItemsSource="{Binding WhoOwesWho}"
                                    SelectionMode="None"
                                    IsVisible="{Binding ShowWhoOwesWhatSection}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                    <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static loc:AppResources.Group_TabBalances}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowBalancesSection}" />

                    <CollectionView ItemsSource="{Binding Balances}"
                                    SelectionMode="None"
                                    IsVisible="{Binding ShowBalancesSection}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPositive}" Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource PositiveSoftGreen}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPositive}" Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource ErrorSoftRed}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label Text="{x:Static loc:AppResources.Home_BalancesEmpty}"
                           Style="{StaticResource BodyMuted}"
                           IsVisible="{Binding ShowBalancesEmptyState}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Ad banner -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
