<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             xmlns:local="clr-namespace:LuSplit.App.Pages"
             x:Class="LuSplit.App.Pages.CreateGroupPage"
             x:Name="PageRoot"
             Title="{x:Static loc:AppResources.CreateGroup_Title}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <Label Text="{x:Static loc:AppResources.CreateGroup_Title}" Style="{StaticResource SectionTitle}" />

                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="8">
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.CreateGroup_GroupName}" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding GroupName}" Placeholder="{x:Static loc:AppResources.CreateGroup_GroupNamePlaceholder}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.CreateGroup_Currency}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding SelectedCurrency}" />
                        </VerticalStackLayout>
                    </Border>
                    <Button Text="{x:Static loc:AppResources.CreateGroup_Continue}" Clicked="OnContinueClicked" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="8">
                    <local:ParticipantsEditorView
                        Participants="{Binding Participants}"
                        CanEdit="True"
                        HostPage="{x:Reference PageRoot}"
                        AddParticipantRequested="OnParticipantAddRequested"
                        RemoveParticipantRequested="OnParticipantRemoveRequested"
                        DependencyChanged="OnDependencyChanged" />
                    <Button Text="{x:Static loc:AppResources.CreateGroup_Create}" Clicked="OnCreateClicked" />
                </VerticalStackLayout>

                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
