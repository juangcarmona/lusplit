<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             x:Class="LuSplit.App.Pages.CreateGroupPage"
             Title="Create group">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <Label Text="Create group" Style="{StaticResource SectionTitle}" />

                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="8">
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Group name" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding GroupName}" Placeholder="Ski trip" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Currency" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding SelectedCurrency}" />
                        </VerticalStackLayout>
                    </Border>
                    <Button Text="Continue" Clicked="OnContinueClicked" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Border Style="{StaticResource FormFieldBorder}">
                            <Entry Text="{Binding NewParticipantName}" Placeholder="Participant name" />
                        </Border>
                        <Button Grid.Column="1" Text="Add" Clicked="OnAddParticipantClicked" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding Participants}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                    <Button Grid.Column="1"
                                            Text="{Binding DependsOnLabel}"
                                            Style="{StaticResource SecondaryButton}"
                                            Clicked="OnSetDependencyClicked"
                                            CommandParameter="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <Button Text="Create" Clicked="OnCreateClicked" />
                </VerticalStackLayout>

                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
