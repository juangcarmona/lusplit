<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.SettlementPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.Settlement_Title}">
    <Grid RowDefinitions="*,Auto">

        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
            <VerticalStackLayout Padding="20,24,20,12" Spacing="6">
                <Label Text="{x:Static loc:AppResources.Settlement_WhoOwesWhat}" Style="{StaticResource DisplayTitle}" />
                <Label Text="{x:Static loc:AppResources.Settlement_Subtitle}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                        Margin="20,0,20,0"
                        ItemsSource="{Binding WhoOwesWho}"
                        SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,40,0,0" Spacing="8">
                        <Label Text="{x:Static loc:AppResources.Settlement_EmptyTitle}" Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="{x:Static loc:AppResources.Settlement_EmptySubtitle}" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Text="{Binding Text}" Style="{StaticResource CardTitle}" />
                                <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource CardAmount}" HorizontalTextAlignment="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Grid.Row="2"
                Margin="20,12,20,20"
                Text="{x:Static loc:AppResources.Settlement_RecordPaymentButton}"
                Clicked="OnRecordPaymentClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>

