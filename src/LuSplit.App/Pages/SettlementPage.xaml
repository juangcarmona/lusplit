<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.SettlementPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             Title="Balances">
    <Grid RowDefinitions="*,Auto">


        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
            <VerticalStackLayout Padding="20,24,20,12" Spacing="6">
                <Label Text="Who owes who" Style="{StaticResource DisplayTitle}" />
                <Label Text="Simple balances for this trip." Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                        Margin="20,0,20,0"
                        ItemsSource="{Binding WhoOwesWho}"
                        SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,40,0,0" Spacing="8">
                        <Label Text="Everyone is even." Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="Record a payment only when money actually changes hands." Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <Label Text="{Binding Text}" Style="{StaticResource CardTitle}" />
                                <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource CardAmount}" HorizontalTextAlignment="End" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid Grid.Row="2" Margin="20,12,20,20" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="+ Add event" Clicked="OnAddEventClicked" />
                <Button Grid.Column="1" Text="Record payment" Clicked="OnRecordPaymentClicked" />
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
