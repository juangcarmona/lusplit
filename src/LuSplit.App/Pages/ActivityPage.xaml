<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.ActivityPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.Activity_Title}">
    <Grid RowDefinitions="*,Auto">

        <Grid RowDefinitions="Auto,*" RowSpacing="0">
            <VerticalStackLayout Padding="20,24,20,12" Spacing="6">
                <Label Text="{x:Static loc:AppResources.Activity_Title}" Style="{StaticResource DisplayTitle}" />
                <Label Text="{x:Static loc:AppResources.Activity_Subtitle}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                        Margin="20,0,20,0"
                        IsGrouped="True"
                        ItemsSource="{Binding ActivityGroups}"
                        SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,40,0,0" Spacing="8">
                        <Label Text="{x:Static loc:AppResources.Activity_EmptyTitle}" Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="{x:Static loc:AppResources.Activity_EmptySubtitle}" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate>
                        <Label Margin="0,12,0,8" Text="{Binding Title}" Style="{StaticResource SectionTitle}" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto">
                                <Label Grid.RowSpan="2"
                                   Text="{Binding Icon}"
                                   FontSize="24"
                                   VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource CardTitle}" />
                                <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource CardAmount}" HorizontalTextAlignment="End" />
                                <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Detail}" Style="{StaticResource BodyMuted}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
