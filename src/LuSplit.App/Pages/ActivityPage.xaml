<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.ActivityPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             Title="History">
    <Grid RowDefinitions="*,Auto">
        <Grid RowDefinitions="Auto,*" RowSpacing="0">
            <VerticalStackLayout Padding="16,16,16,8" Spacing="2">
                <Label Text="History" Style="{StaticResource SectionTitle}" />
                <Label Text="{Binding Subtitle}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>

            <CollectionView Grid.Row="1"
                            Margin="16,0,16,0"
                            IsGrouped="False"
                            ItemsSource="{Binding Events}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <Label Text="No events yet" Style="{StaticResource BodyMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                            <Label Grid.RowSpan="2"
                                   Text="{Binding Icon}"
                                   FontSize="18"
                                   VerticalTextAlignment="Start" />
                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Label Text="{Binding Title}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding Subtitle}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
