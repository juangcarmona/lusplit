<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.LanguageSettingsPage"
             Title="{x:Static loc:AppResources.Settings_Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,24" Spacing="14">

            <Label Text="{x:Static loc:AppResources.Settings_Title}"
                   Style="{StaticResource DisplayTitle}" />

            <Label Text="{x:Static loc:AppResources.Settings_LanguageSection}"
                   Style="{StaticResource SectionTitle}"
                   Margin="0,8,0,0" />

            <Label Text="{x:Static loc:AppResources.Settings_LanguageHint}"
                   Style="{StaticResource BodyMuted}" />

            <CollectionView ItemsSource="{Binding Languages}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <Label Text="{Binding DisplayLabel}"
                                       Style="{StaticResource BodyText}"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="✓"
                                       IsVisible="{Binding IsSelected}"
                                       Style="{StaticResource CardAmount}"
                                       TextColor="{StaticResource PanelLeftTeal}"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnLanguageTapped"
                                    CommandParameter="{Binding Culture}" />
                            </Border.GestureRecognizers>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
