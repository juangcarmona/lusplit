<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.LanguageSettingsPage"
             Title="{x:Static loc:AppResources.Settings_Title}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
        <Border Padding="10,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Text="←"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="Start"
                        Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                       Text="{x:Static loc:AppResources.Settings_Title}"
                       FontFamily="BrandMedium"
                       FontSize="20"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Start" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button x:Name="ProfileTabButton"
                            Grid.Column="0"
                            Text="{x:Static loc:AppResources.Settings_ProfileSection}"
                            Clicked="OnProfileTabClicked" />
                    <Button x:Name="LanguageTabButton"
                            Grid.Column="1"
                            Text="{x:Static loc:AppResources.Settings_LanguageSection}"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnLanguageTabClicked" />
                </Grid>

                <VerticalStackLayout IsVisible="{Binding ShowProfileTab}" Spacing="10">
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.Settings_MyNameLabel}" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding PreferredName}" Placeholder="{x:Static loc:AppResources.Settings_MyNamePlaceholder}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.GroupDetails_CurrencyLabel}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding SelectedCurrency}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource FormFieldBorder}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="Dark theme" Style="{StaticResource BodyText}" VerticalTextAlignment="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsDarkThemeEnabled}" />
                        </Grid>
                    </Border>

                    <Button Text="{x:Static loc:AppResources.Settings_SaveProfileButton}"
                            Clicked="OnSaveProfileClicked" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding ShowLanguageTab}" Spacing="10">
                    <Label Text="{x:Static loc:AppResources.Settings_LanguageHint}" Style="{StaticResource BodyMuted}" />
                    <CollectionView ItemsSource="{Binding Languages}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ExpenseItemBorder}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Text="{Binding DisplayLabel}" Style="{StaticResource BodyText}" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="✓"
                                               IsVisible="{Binding IsSelected}"
                                               Style="{StaticResource CardAmount}"
                                               TextColor="{StaticResource PanelLeftTeal}"
                                               HorizontalTextAlignment="End"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnLanguageTapped"
                                            CommandParameter="{Binding Culture}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
