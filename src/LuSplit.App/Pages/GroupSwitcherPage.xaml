<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.GroupSwitcherPage"
             Title="{x:Static loc:AppResources.GroupSwitcher_Title}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
        <Border Padding="10,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Text="←"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="Start"
                        Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                       Text="{x:Static loc:AppResources.GroupSwitcher_Title}"
                       FontFamily="BrandMedium"
                       FontSize="20"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Start" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <CollectionView ItemsSource="{Binding ActiveGroups}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0,4">
                                <Label Text="{Binding DisplayName}" Style="{StaticResource BodyText}" />
                                <Button Grid.Column="1"
                                        Text="{x:Static loc:AppResources.GroupSwitcher_Select}"
                                        Clicked="OnSelectGroupClicked"
                                        CommandParameter="{Binding GroupId}"
                                        IsEnabled="{Binding CanSelect}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="{x:Static loc:AppResources.GroupSwitcher_ArchivedToggle}" Style="{StaticResource SecondaryButton}" Clicked="OnToggleArchivedClicked" />
                <CollectionView ItemsSource="{Binding ArchivedGroups}" SelectionMode="None" IsVisible="{Binding ShowArchived}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0,4">
                                <Label Text="{Binding Name}" Style="{StaticResource BodyMuted}" />
                                <Button Grid.Column="1"
                                        Text="{x:Static loc:AppResources.GroupSwitcher_Select}"
                                        Clicked="OnSelectGroupClicked"
                                        CommandParameter="{Binding GroupId}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="{x:Static loc:AppResources.GroupSwitcher_NewGroup}" Clicked="OnNewGroupClicked" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
