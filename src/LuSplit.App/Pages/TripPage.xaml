<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.TripPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             Title="Trip">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Details" Clicked="OnTripDetailsClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,24" Spacing="16">

                <!-- Trip header -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding TripName}" Style="{StaticResource DisplayTitle}" />
                    <Label Text="{Binding TripSummaryText}" Style="{StaticResource BodyMuted}" />
                </VerticalStackLayout>

                <!-- Balance summary card -->
                <Border Style="{StaticResource ExpenseItemBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Who owes what" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding BalanceLines}"
                                        SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="Everyone is even right now." Style="{StaticResource BodyText}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,0,0,6">
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource CardAmount}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Button Text="Settle up"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalOptions="Start"
                                Clicked="OnSettleUpClicked" />
                    </VerticalStackLayout>
                </Border>

                <!-- Events section -->
                <Label Text="Events" Style="{StaticResource SectionTitle}" Margin="0,4,0,0" />

                <CollectionView ItemsSource="{Binding TimelineItems}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="0,16,0,0" Spacing="8">
                            <Label Text="Your trip just started."
                                   Style="{StaticResource SectionTitle}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Add the first expense below."
                                   Style="{StaticResource BodyMuted}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ExpenseItemBorder}">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto">
                                    <Label Grid.RowSpan="3"
                                           Text="{Binding Icon}"
                                           FontSize="28"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="1" Text="{Binding Title}" Style="{StaticResource CardTitle}" />
                                    <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource CardAmount}" HorizontalTextAlignment="End" />
                                    <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding PrimaryText}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding SecondaryText}" Style="{StaticResource BodyMuted}" />
                                    <Label Grid.Row="2" Grid.Column="2" Text="{Binding DateText}" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Quick actions -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                    <Button Grid.Column="0" Text="+ Add expense" Clicked="OnAddEventClicked" />
                    <Button Grid.Column="1"
                            Text="Record payment"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnRecordPaymentClicked" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Ad banner -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>