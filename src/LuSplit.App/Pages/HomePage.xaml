<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="Trips">
    <Grid RowDefinitions="*,Auto">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
            <ScrollView>
                <VerticalStackLayout Padding="20,24,20,12" Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Trips" Style="{StaticResource DisplayTitle}" />
                        <Label Text="Pick up where you left off or start a new trip." Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>

                    <Border IsVisible="{Binding HasCurrentTrip}" Style="{StaticResource ExpenseItemBorder}">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Current trip" Style="{StaticResource FieldLabel}" />
                            <Label Text="{Binding CurrentTripName}" Style="{StaticResource SectionTitle}" />
                            <Label Text="{Binding CurrentTripSummaryText}" Style="{StaticResource BodyText}" />
                            <Label Text="{Binding CurrentTripBalanceText}" Style="{StaticResource BodyMuted}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Button Grid.Column="0" Text="Open trip" Clicked="OnOpenCurrentTripClicked" />
                                <Button Grid.Column="1" Text="Trip details" Clicked="OnEditCurrentTripClicked" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <CollectionView ItemsSource="{Binding Trips}" SelectionMode="None">
                        <CollectionView.Header>
                            <Label Margin="0,0,0,12" Text="All trips" Style="{StaticResource SectionTitle}" />
                        </CollectionView.Header>
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="0,24,0,0" Spacing="8">
                                <Label Text="No trips yet." Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                                <Label Text="Create your first trip and start adding events." Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ExpenseItemBorder}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding StatusText}" Style="{StaticResource FieldLabel}" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}" Style="{StaticResource CardTitle}" />
                                                <Label Text="{Binding SummaryText}" Style="{StaticResource BodyText}" />
                                                <Label Text="{Binding BalancePreviewText}" Style="{StaticResource BodyMuted}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1"
                                               Text="{Binding Currency}"
                                               Style="{StaticResource BodyMuted}"
                                               VerticalTextAlignment="Start" />
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Button Grid.Column="0"
                                                Text="Open"
                                                Clicked="OnOpenTripClicked"
                                                CommandParameter="{Binding GroupId}" />
                                            <Button Grid.Column="1"
                                                Text="Details"
                                                Clicked="OnEditTripClicked"
                                                CommandParameter="{Binding GroupId}" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="2"
                Margin="20,12,20,20"
                Text="+ New trip"
                Clicked="OnNewTripClicked" />
        </Grid>


        <Border Grid.Row="1"
                BackgroundColor="{StaticResource CardDark}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
