<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="{x:Static loc:AppResources.Home_Title}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*,Auto">
        <Grid RowDefinitions="*,Auto" RowSpacing="0">
            <VerticalStackLayout Padding="24,24,24,12"
                                 Spacing="12"
                                 IsVisible="{Binding ShowNoGroupsEmptyState}"
                                 VerticalOptions="Center">
                <Label Text="{x:Static loc:AppResources.Home_NoGroupsTitle}"
                       Style="{StaticResource DisplayTitle}"
                       HorizontalTextAlignment="Center" />
                <Label Text="{x:Static loc:AppResources.Home_NoGroupsSubtitle}"
                       Style="{StaticResource BodyMuted}"
                       HorizontalTextAlignment="Center" />
                <Button Text="{x:Static loc:AppResources.CreateGroup_Title}"
                        Clicked="OnCreateGroupClicked"
                        HorizontalOptions="Fill" />
            </VerticalStackLayout>

            <ScrollView IsVisible="{Binding HasGroup}">
                <VerticalStackLayout Padding="16,16,16,8" Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="☰"
                                Clicked="OnOpenDrawerClicked"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                MinimumWidthRequest="42"
                                MinimumHeightRequest="36" />
                        <Label Grid.Column="1"
                               Text="{Binding GroupName}"
                               FontFamily="BrandSemiBold"
                               FontSize="24"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryNavy}, Dark={StaticResource TextOnDark}}"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                        <Button Grid.Column="2"
                                Text="⋯"
                                Clicked="OnOverflowClicked"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                MinimumWidthRequest="42"
                                MinimumHeightRequest="36" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button x:Name="OverviewTabButton"
                                Grid.Column="0"
                                Text="{x:Static loc:AppResources.Group_TabOverview}"
                                Clicked="OnOverviewTabClicked" />
                        <Button x:Name="ExpensesTabButton"
                                Grid.Column="1"
                                Text="{x:Static loc:AppResources.Group_TabExpenses}"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnExpensesTabClicked" />
                        <Button x:Name="BalancesTabButton"
                                Grid.Column="2"
                                Text="{x:Static loc:AppResources.Group_TabBalances}"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnBalancesTabClicked" />
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding ShowOverview}" Spacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding GroupMetaText}" Style="{StaticResource BodyMuted}" />
                            <Label Text="{Binding TotalUnsettledText}" Style="{StaticResource BodyText}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding ShowOverviewEmptyState}" Spacing="2">
                            <Label Text="{x:Static loc:AppResources.Home_OverviewNoActivityCount}" Style="{StaticResource BodyMuted}" />
                            <Label Text="{x:Static loc:AppResources.Home_OverviewNoActivityText}" Style="{StaticResource BodyMuted}" />
                        </VerticalStackLayout>

                        <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowWhoOwesWhatSection}" />
                        <CollectionView ItemsSource="{Binding WhoOwesWho}" SelectionMode="None" IsVisible="{Binding ShowWhoOwesWhatSection}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Group_TabBalances}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowBalancesSection}" />
                        <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None" IsVisible="{Binding ShowBalancesSection}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               TextColor="{Binding AmountColor}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Home_RecentExpenses}" Style="{StaticResource SectionTitle}" IsVisible="{Binding HasEvents}" />
                        <CollectionView ItemsSource="{Binding Events}" SelectionMode="Single" Margin="0,6,0,0" SelectionChanged="OnEventSelectionChanged" IsVisible="{Binding HasEvents}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="{Binding Line1}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Label Text="{Binding Line2}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="›" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowExpenses}" Spacing="10">
                        <Label Text="{x:Static loc:AppResources.Group_TabExpenses}" Style="{StaticResource SectionTitle}" IsVisible="{Binding HasEvents}" />
                        <CollectionView ItemsSource="{Binding Events}" SelectionMode="Single" Margin="0,2,0,0" SelectionChanged="OnEventSelectionChanged" IsVisible="{Binding HasEvents}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="{Binding Line1}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Label Text="{Binding Line2}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="›" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Label Text="{x:Static loc:AppResources.Home_ExpensesEmpty}"
                               Style="{StaticResource BodyMuted}"
                               IsVisible="{Binding ShowExpensesEmptyState}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowBalances}" Spacing="10">
                        <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowWhoOwesWhatSection}" />
                        <CollectionView ItemsSource="{Binding WhoOwesWho}" SelectionMode="None" IsVisible="{Binding ShowWhoOwesWhatSection}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Group_TabBalances}" Style="{StaticResource SectionTitle}" IsVisible="{Binding ShowBalancesSection}" />
                        <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None" IsVisible="{Binding ShowBalancesSection}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               TextColor="{Binding AmountColor}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Home_BalancesEmpty}"
                               Style="{StaticResource BodyMuted}"
                               IsVisible="{Binding ShowBalancesEmptyState}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <Grid Grid.Row="1">
                <Button Margin="16,8,16,8"
                        Text="{x:Static loc:AppResources.Group_AddExpense}"
                        Clicked="OnAddExpenseClicked"
                        IsVisible="{Binding ShowAddExpenseButton}" />
                <Button Margin="16,8,16,8"
                        Text="{x:Static loc:AppResources.Group_SettleUp}"
                        Clicked="OnSettleUpClicked"
                        IsVisible="{Binding ShowSettleUpButton}" />
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
