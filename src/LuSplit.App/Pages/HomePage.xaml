<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="Trips">
    <Grid RowDefinitions="*,Auto">

        <!-- Main content: scrollable trip list + New trip button -->
        <Grid RowDefinitions="*,Auto" RowSpacing="0">
            <ScrollView>
                <VerticalStackLayout Padding="20,24,20,12" Spacing="16">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Trips" Style="{StaticResource DisplayTitle}" />
                        <Label Text="Pick up where you left off or start a new trip." Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding Trips}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Padding="0,24,0,0" Spacing="8">
                                <Label Text="No trips yet." Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                                <Label Text="Create your first trip and start adding events." Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ExpenseItemBorder}">
                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="{Binding Name}" Style="{StaticResource CardTitle}" />
                                                <Label Text="{Binding SummaryText}" Style="{StaticResource BodyText}" />
                                                <Label Text="{Binding BalancePreviewText}" Style="{StaticResource BodyMuted}" />
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Start">
                                                <Label Text="{Binding Currency}" Style="{StaticResource BodyMuted}" HorizontalTextAlignment="End" />
                                                <Border Style="{StaticResource PillBorder}" IsVisible="{Binding IsCurrent}">
                                                    <Label Text="Active" Style="{StaticResource PillLabel}" TextColor="{StaticResource PanelLeftTeal}" />
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <Button Grid.Column="0"
                                                Text="Open"
                                                Clicked="OnOpenTripClicked"
                                                CommandParameter="{Binding GroupId}" />
                                            <Button Grid.Column="1"
                                                Text="Details"
                                                Style="{StaticResource SecondaryButton}"
                                                Clicked="OnEditTripClicked"
                                                CommandParameter="{Binding GroupId}"
                                                WidthRequest="100" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="1"
                Margin="20,12,20,20"
                Text="+ New trip"
                Clicked="OnNewTripClicked" />
        </Grid>

        <!-- Ad banner -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
