<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="Home">
    <Grid RowDefinitions="*,Auto">
        <Grid RowDefinitions="*,Auto,Auto" RowSpacing="0">
            <ScrollView>
                <VerticalStackLayout Padding="16,16,16,8" Spacing="10">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding GroupName}" Style="{StaticResource SectionTitle}" />
                        <Label Text="{Binding GroupMetaText}" Style="{StaticResource BodyMuted}" />
                        <Label Text="{Binding TotalUnsettledText}" Style="{StaticResource BodyText}" />
                    </VerticalStackLayout>

                    <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No balances yet" Style="{StaticResource BodyMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                    <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding AmountText}"
                                           Style="{StaticResource BodyText}"
                                           TextColor="{Binding AmountColor}"
                                           HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView ItemsSource="{Binding SettlementSuggestions}" SelectionMode="None" Margin="0,6,0,0">
                        <CollectionView.EmptyView>
                            <Label Text="All settled" Style="{StaticResource BodyMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Padding="0,3">
                                    <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                    <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" />
                                    <Button Grid.Column="2"
                                            Text="Pay"
                                            Clicked="OnPaySuggestionClicked"
                                            CommandParameter="{Binding CommandParameter}"
                                            Padding="8,4"
                                            MinimumHeightRequest="30"
                                            HeightRequest="30" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView ItemsSource="{Binding Events}" SelectionMode="None" Margin="0,6,0,0">
                        <CollectionView.EmptyView>
                            <Label Text="No events yet" Style="{StaticResource BodyMuted}" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                    <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="{Binding Title}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding Subtitle}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="1"
                    Margin="16,8,16,4"
                    Text="+ Expense"
                    Clicked="OnAddExpenseClicked" />
            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="16,0,16,8">
                <Button Grid.Column="0" Text="Pay" Style="{StaticResource SecondaryButton}" Clicked="OnPayClicked" />
                <Button Grid.Column="1" Text="Details" Style="{StaticResource SecondaryButton}" Clicked="OnEditGroupClicked" />
                <Button Grid.Column="2" Text="Archived" Style="{StaticResource SecondaryButton}" Clicked="OnViewArchivedClicked" />
            </Grid>
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
