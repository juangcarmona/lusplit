<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="{x:Static loc:AppResources.Home_Title}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*,Auto">
        <Grid RowDefinitions="*,Auto" RowSpacing="0">
            <ScrollView>
                <VerticalStackLayout Padding="16,16,16,8" Spacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="☰"
                                Clicked="OnOpenDrawerClicked"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                MinimumWidthRequest="42"
                                MinimumHeightRequest="36" />
                        <Label Grid.Column="1"
                               Text="{Binding GroupName}"
                               FontFamily="BrandSemiBold"
                               FontSize="24"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryNavy}, Dark={StaticResource TextOnDark}}"
                               VerticalTextAlignment="Center"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="TailTruncation"
                               MaxLines="1" />
                        <Button Grid.Column="2"
                                Text="⋯"
                                Clicked="OnOverflowClicked"
                                Style="{StaticResource SecondaryButton}"
                                Padding="10,6"
                                MinimumWidthRequest="42"
                                MinimumHeightRequest="36" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button x:Name="OverviewTabButton"
                                Grid.Column="0"
                                Text="{x:Static loc:AppResources.Group_TabOverview}"
                                Clicked="OnOverviewTabClicked" />
                        <Button x:Name="ExpensesTabButton"
                                Grid.Column="1"
                                Text="{x:Static loc:AppResources.Group_TabExpenses}"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnExpensesTabClicked" />
                        <Button x:Name="BalancesTabButton"
                                Grid.Column="2"
                                Text="{x:Static loc:AppResources.Group_TabBalances}"
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnBalancesTabClicked" />
                    </Grid>

                    <VerticalStackLayout IsVisible="{Binding ShowOverview}" Spacing="10">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="{Binding GroupMetaText}" Style="{StaticResource BodyMuted}" />
                            <Label Text="{Binding TotalUnsettledText}" Style="{StaticResource BodyText}" />
                        </VerticalStackLayout>

                        <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding WhoOwesWho}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Group_EveryoneEven}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Group_TabBalances}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Home_NoBalancesYet}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               TextColor="{Binding AmountColor}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Home_RecentExpenses}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding Events}" SelectionMode="None" Margin="0,6,0,0">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Activity_EmptyTitle}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="{Binding Title}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Label Text="{Binding Subtitle}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowExpenses}" Spacing="10">
                        <Label Text="{x:Static loc:AppResources.Group_TabExpenses}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding Events}" SelectionMode="None" Margin="0,2,0,0">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Activity_EmptyTitle}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,4">
                                        <Label Text="{Binding Icon}" FontSize="18" VerticalTextAlignment="Start" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="0">
                                            <Label Text="{Binding Title}" Style="{StaticResource BodyText}" LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Label Text="{Binding Subtitle}" Style="{StaticResource BodyMuted}" LineBreakMode="TailTruncation" MaxLines="1" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout IsVisible="{Binding ShowBalances}" Spacing="10">
                        <Label Text="{x:Static loc:AppResources.Group_WhoOwesWhat}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding WhoOwesWho}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Group_EveryoneEven}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="{x:Static loc:AppResources.Group_TabBalances}" Style="{StaticResource SectionTitle}" />
                        <CollectionView ItemsSource="{Binding Balances}" SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Label Text="{x:Static loc:AppResources.Home_NoBalancesYet}" Style="{StaticResource BodyMuted}" />
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,3">
                                        <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               Style="{StaticResource BodyText}"
                                               TextColor="{Binding AmountColor}"
                                               HorizontalTextAlignment="End" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Button Text="{x:Static loc:AppResources.Group_SettleUp}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalOptions="Start"
                                Clicked="OnSettleUpClicked" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>

            <Button Grid.Row="1"
                    Margin="16,8,16,8"
                    Text="{x:Static loc:AppResources.Group_AddExpense}"
                    Clicked="OnAddExpenseClicked" />
        </Grid>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
