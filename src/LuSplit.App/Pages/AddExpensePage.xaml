<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.AddEvent_Title}">
    <Grid RowDefinitions="*,Auto,Auto" RowSpacing="0">
        <ScrollView>
            <VerticalStackLayout Padding="14,10,14,10" Spacing="8">
                <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                <Entry x:Name="AmountEntry"
                       Text="{Binding AmountText}"
                       TextChanged="OnAmountTextChanged"
                       Keyboard="Numeric"
                       Placeholder="100"
                       FontSize="36" />

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource StrokeLight}, Dark={StaticResource StrokeDark}}" />

                <Label Text="{x:Static loc:AppResources.AddEvent_PaidBy}" Style="{StaticResource FieldLabel}" />
                <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" SelectedIndexChanged="OnPayerChanged" />

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource StrokeLight}, Dark={StaticResource StrokeDark}}" />

                <Grid ColumnDefinitions="Auto,*,*,*" ColumnSpacing="8">
                    <Label Text="{x:Static loc:AppResources.AddEvent_SplitLabel}" Style="{StaticResource FieldLabel}" VerticalTextAlignment="Center" />
                    <Button Grid.Column="1" x:Name="EqualModeButton" Text="{x:Static loc:AppResources.AddEvent_SplitEqual}" Clicked="OnEqualModeClicked" />
                    <Button Grid.Column="2" x:Name="ExactModeButton" Text="{x:Static loc:AppResources.AddEvent_SplitExact}" Style="{StaticResource SecondaryButton}" Clicked="OnExactModeClicked" />
                    <Button Grid.Column="3" x:Name="PercentModeButton" Text="{x:Static loc:AppResources.AddEvent_SplitPercent}" Style="{StaticResource SecondaryButton}" Clicked="OnPercentModeClicked" />
                </Grid>

                <Label Text="{x:Static loc:AppResources.AddEvent_WhoJoined}" Style="{StaticResource SectionTitle}" />
                <CollectionView ItemsSource="{Binding ParticipantRows}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8" Padding="0,4">
                                <Label Text="{Binding IsIncludedMark}" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Name}"
                                       VerticalTextAlignment="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnParticipantRowTapped" CommandParameter="{Binding Id}" />
                                    </Label.GestureRecognizers>
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsIncluded}" Value="False">
                                            <Setter Property="Opacity" Value="0.45" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>

                                <Entry Grid.Column="2"
                                       Text="{Binding EditableValue}"
                                       Keyboard="Numeric"
                                       HorizontalTextAlignment="End"
                                       TextChanged="OnParticipantAmountEdited"
                                       Completed="OnParticipantAmountEditCompleted">
                                    <Entry.Triggers>
                                        <DataTrigger TargetType="Entry" Binding="{Binding IsIncluded}" Value="False">
                                            <Setter Property="Opacity" Value="0.45" />
                                        </DataTrigger>
                                    </Entry.Triggers>
                                </Entry>

                                <Button Grid.Column="3"
                                        Text="-"
                                        Clicked="OnDecreaseParticipantAmountClicked"
                                        CommandParameter="{Binding Id}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,2"
                                        MinimumWidthRequest="34"
                                        MinimumHeightRequest="34" />
                                <Button Grid.Column="4"
                                        Text="+"
                                        Clicked="OnIncreaseParticipantAmountClicked"
                                        CommandParameter="{Binding Id}"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="8,2"
                                        MinimumWidthRequest="34"
                                        MinimumHeightRequest="34" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{x:Static loc:AppResources.AddEvent_ImpactTitle}" Style="{StaticResource SectionTitle}" />
                <CollectionView ItemsSource="{Binding ImpactRows}" SelectionMode="None" HeightRequest="96">
                    <CollectionView.EmptyView>
                        <Label Text="{x:Static loc:AppResources.AddEvent_ImpactHint}" Style="{StaticResource BodyMuted}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{x:Static loc:AppResources.AddEvent_NoteLabel}" Style="{StaticResource FieldLabel}" />
                <Entry Text="{Binding ExpenseTitle}"
                       TextChanged="OnExpenseTitleChanged"
                       Placeholder="{x:Static loc:AppResources.AddEvent_NotePlaceholder}" />

                <Label Text="{x:Static loc:AppResources.Common_Date}" Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding ExpenseDate}" />

                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                Padding="12,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundSnow}, Dark={StaticResource BackgroundDark}}"
                StrokeThickness="0">
            <Button Text="{x:Static loc:AppResources.AddEvent_SaveButton}"
                    Clicked="OnSaveClicked"
                    IsEnabled="{Binding CanSave}" />
        </Border>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
