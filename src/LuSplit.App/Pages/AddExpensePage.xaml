<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.AddEvent_Title}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="8,8,8,8" Spacing="4">
                <Label Text="{x:Static loc:AppResources.AddEvent_Title}" Style="{StaticResource DisplayTitle}" />
                <Label Text="{x:Static loc:AppResources.AddEvent_Subtitle}" Style="{StaticResource BodyMuted}" />

                <Label Text="{x:Static loc:AppResources.AddEvent_WhatHappened}" Style="{StaticResource SectionTitle}" />
                <FlexLayout Wrap="Wrap" Direction="Row">
                    <Button Margin="0,0,2,2" Text="{x:Static loc:AppResources.AddEvent_QuickDinner}" Clicked="OnQuickChoiceClicked" CommandParameter="{x:Static loc:AppResources.AddEvent_QuickDinner}" />
                    <Button Margin="0,0,2,2" Text="{x:Static loc:AppResources.AddEvent_QuickTaxi}" Clicked="OnQuickChoiceClicked" CommandParameter="{x:Static loc:AppResources.AddEvent_QuickTaxi}" />
                    <Button Margin="0,0,2,2" Text="{x:Static loc:AppResources.AddEvent_QuickGroceries}" Clicked="OnQuickChoiceClicked" CommandParameter="{x:Static loc:AppResources.AddEvent_QuickGroceries}" />
                    <Button Margin="0,0,2,2" Text="{x:Static loc:AppResources.AddEvent_QuickTickets}" Clicked="OnQuickChoiceClicked" CommandParameter="{x:Static loc:AppResources.AddEvent_QuickTickets}" />
                    <Button Margin="0,0,2,2" Text="{x:Static loc:AppResources.AddEvent_QuickCustom}" Clicked="OnQuickChoiceClicked" CommandParameter="" />
                </FlexLayout>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_EventLabel}" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding ExpenseTitle}" Placeholder="{x:Static loc:AppResources.AddEvent_EventPlaceholder}" ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding AmountText}" Keyboard="Numeric" Placeholder="12.50" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.Common_Date}" Style="{StaticResource FieldLabel}" />
                            <DatePicker Date="{Binding ExpenseDate}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_PaidBy}" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{x:Static loc:AppResources.AddEvent_WhoJoined}" Style="{StaticResource SectionTitle}" />
                <Label Text="{x:Static loc:AppResources.AddEvent_EveryoneDefault}" Style="{StaticResource BodyMuted}" />
                <FlexLayout Wrap="Wrap" Direction="Row" BindableLayout.ItemsSource="{Binding ParticipantOptions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ChipBorder}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <Button Text="{x:Static loc:AppResources.AddEvent_SaveButton}" Clicked="OnSaveClicked" />
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
