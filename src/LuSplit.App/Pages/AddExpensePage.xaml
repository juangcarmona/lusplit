<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.AddEvent_Title}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="8,8,8,8" Spacing="6">
                <Label Text="{x:Static loc:AppResources.AddEvent_Title}" Style="{StaticResource DisplayTitle}" />
                <Label Text="{x:Static loc:AppResources.AddEvent_Subtitle}" Style="{StaticResource BodyMuted}" />

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_EventLabel}" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding ExpenseTitle}" TextChanged="OnExpenseTitleChanged" Placeholder="{x:Static loc:AppResources.AddEvent_EventPlaceholder}" ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding AmountText}" TextChanged="OnAmountTextChanged" Keyboard="Numeric" Placeholder="12.50" FontSize="22" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_PaidBy}" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" />
                        <Label Text="{x:Static loc:AppResources.AddEvent_PayerHint}" Style="{StaticResource BodyMuted}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{x:Static loc:AppResources.AddEvent_WhoJoined}" Style="{StaticResource SectionTitle}" />
                <Label Text="{x:Static loc:AppResources.AddEvent_ParticipantHint}" Style="{StaticResource BodyMuted}" />
                <CollectionView ItemsSource="{Binding ParticipantOptions}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="6" HorizontalItemSpacing="6" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ChipBorder}" Margin="0">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                    <CheckBox IsChecked="{Binding IsSelected}" CheckedChanged="OnParticipantCheckedChanged" VerticalOptions="Center" />
                                    <VerticalStackLayout Grid.Column="1" Spacing="0">
                                        <Label Text="{Binding Name}" VerticalTextAlignment="Center" />
                                        <Label Text="{Binding RelationshipHint}" Style="{StaticResource BodyMuted}" IsVisible="{Binding HasRelationshipHint}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.Common_Date}" Style="{StaticResource FieldLabel}" />
                            <DatePicker Date="{Binding ExpenseDate}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Label Text="{x:Static loc:AppResources.AddEvent_SplitPreviewTitle}" Style="{StaticResource SectionTitle}" />
                <CollectionView ItemsSource="{Binding SplitPreview}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Label Text="{x:Static loc:AppResources.AddEvent_SplitPreviewHint}" Style="{StaticResource BodyMuted}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                <Label Text="{Binding Name}" Style="{StaticResource BodyText}" />
                                <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" HorizontalTextAlignment="End" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="{x:Static loc:AppResources.AddEvent_SaveButton}" Clicked="OnSaveClicked" IsEnabled="{Binding CanSave}" />
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
