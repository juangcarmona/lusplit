<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.AddEvent_Title}"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">
        <Border Padding="10,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <Button Text="←"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="Start"
                        Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                       Text="{x:Static loc:AppResources.AddEvent_Title}"
                       FontFamily="BrandMedium"
                       FontSize="20"
                       VerticalTextAlignment="Center"
                       HorizontalTextAlignment="Start" />
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="12,12,12,8" Spacing="8">
                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                        <Entry x:Name="AmountEntry"
                               Text="{Binding AmountText}"
                               TextChanged="OnAmountTextChanged"
                               Keyboard="Numeric"
                               Placeholder="36.00"
                               FontSize="34" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_PaidBy}" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" SelectedIndexChanged="OnPayerChanged" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="{x:Static loc:AppResources.AddEvent_WhoJoined}" Style="{StaticResource SectionTitle}" />
                <CollectionView ItemsSource="{Binding ParticipantRows}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource FormFieldBorder}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnParticipantRowTapped" CommandParameter="{Binding Id}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                    <Label Text="{Binding Name}"
                                           VerticalTextAlignment="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsIncluded}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Label Grid.Column="1"
                                           Text="{Binding AmountText}"
                                           VerticalTextAlignment="Center"
                                           HorizontalTextAlignment="End">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsIncluded}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Button Grid.Column="2"
                                            Text="-"
                                            Clicked="OnDecreaseParticipantAmountClicked"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,2"
                                            MinimumWidthRequest="34"
                                            MinimumHeightRequest="34" />
                                    <Button Grid.Column="3"
                                            Text="+"
                                            Clicked="OnIncreaseParticipantAmountClicked"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,2"
                                            MinimumWidthRequest="34"
                                            MinimumHeightRequest="34" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{x:Static loc:AppResources.AddEvent_ImpactTitle}" Style="{StaticResource SectionTitle}" />
                <CollectionView ItemsSource="{Binding ImpactRows}" SelectionMode="None" HeightRequest="120">
                    <CollectionView.EmptyView>
                        <Label Text="{x:Static loc:AppResources.AddEvent_ImpactHint}" Style="{StaticResource BodyMuted}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.AddEvent_NoteLabel}" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding ExpenseTitle}"
                               TextChanged="OnExpenseTitleChanged"
                               Placeholder="{x:Static loc:AppResources.AddEvent_NotePlaceholder}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static loc:AppResources.Common_Date}" Style="{StaticResource FieldLabel}" />
                        <DatePicker Date="{Binding ExpenseDate}" />
                    </VerticalStackLayout>
                </Border>

                <Button Text="{x:Static loc:AppResources.AddEvent_SaveButton}"
                        Clicked="OnSaveClicked"
                        IsEnabled="{Binding CanSave}" />
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
