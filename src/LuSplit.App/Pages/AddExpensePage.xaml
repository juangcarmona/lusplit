<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             Title="Add event">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
                <Label Text="Add event" Style="{StaticResource DisplayTitle}" />
                <Label Text="Record what just happened." Style="{StaticResource BodyMuted}" />

                <Label Text="What happened?" Style="{StaticResource SectionTitle}" />
                <FlexLayout Wrap="Wrap" Direction="Row">
                    <Button Margin="0,0,8,8" Text="Dinner" Clicked="OnQuickChoiceClicked" CommandParameter="Dinner" />
                    <Button Margin="0,0,8,8" Text="Taxi" Clicked="OnQuickChoiceClicked" CommandParameter="Taxi" />
                    <Button Margin="0,0,8,8" Text="Groceries" Clicked="OnQuickChoiceClicked" CommandParameter="Groceries" />
                    <Button Margin="0,0,8,8" Text="Tickets" Clicked="OnQuickChoiceClicked" CommandParameter="Tickets" />
                    <Button Margin="0,0,8,8" Text="Custom" Clicked="OnQuickChoiceClicked" CommandParameter="" />
                </FlexLayout>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Event" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding ExpenseTitle}" Placeholder="Dinner, groceries, ride..." ClearButtonVisibility="WhileEditing" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Amount" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding AmountText}" Keyboard="Numeric" Placeholder="12.50" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Date" Style="{StaticResource FieldLabel}" />
                            <DatePicker Date="{Binding ExpenseDate}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Paid by" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" />
                    </VerticalStackLayout>
                </Border>

                <Label Text="Who joined?" Style="{StaticResource SectionTitle}" />
                <Label Text="Everyone is included by default." Style="{StaticResource BodyMuted}" />
                <FlexLayout Wrap="Wrap" Direction="Row" BindableLayout.ItemsSource="{Binding ParticipantOptions}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ChipBorder}">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" VerticalTextAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <Button Text="Save event" Clicked="OnSaveClicked" />
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeThickness="0"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
