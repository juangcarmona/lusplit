<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.RecordPaymentPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.RecordPayment_Title}">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
                <Label Text="{x:Static loc:AppResources.RecordPayment_Title}" Style="{StaticResource DisplayTitle}" />
                <Label Text="{x:Static loc:AppResources.RecordPayment_Subtitle}" Style="{StaticResource BodyMuted}" />

                <VerticalStackLayout IsVisible="{Binding IsQuickMode}" Spacing="8">
                    <Label Text="{x:Static loc:AppResources.RecordPayment_SuggestionTitle}" Style="{StaticResource SectionTitle}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Text="{Binding QuickSummaryText}" Style="{StaticResource BodyText}" />
                        <Label Grid.Column="1" Text="{Binding AmountText}" Style="{StaticResource BodyText}" />
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static loc:AppResources.RecordPayment_WhoPaid}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding PersonNames}" SelectedItem="{Binding SelectedFromName}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{x:Static loc:AppResources.RecordPayment_WhoReceived}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding PersonNames}" SelectedItem="{Binding SelectedToName}" />
                        </VerticalStackLayout>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                                <Entry Text="{Binding AmountText}" Keyboard="Numeric" Placeholder="12.50" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource FormFieldBorder}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{x:Static loc:AppResources.Common_Date}" Style="{StaticResource FieldLabel}" />
                                <DatePicker Date="{Binding PaymentDate}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Button Text="{x:Static loc:AppResources.RecordPayment_SaveButton}" Clicked="OnSaveClicked" />
                </VerticalStackLayout>
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
