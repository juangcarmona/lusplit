<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.RecordPaymentPage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             Title="Record payment">
    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
                <Label Text="Record payment" Style="{StaticResource DisplayTitle}" />
                <Label Text="Capture a real payment and keep the trip timeline honest." Style="{StaticResource BodyMuted}" />

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Who paid?" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PersonNames}" SelectedItem="{Binding SelectedFromName}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Who received it?" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PersonNames}" SelectedItem="{Binding SelectedToName}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Amount" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding AmountText}" Keyboard="Numeric" Placeholder="12.50" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Date" Style="{StaticResource FieldLabel}" />
                            <DatePicker Date="{Binding PaymentDate}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Button Text="Save payment" Clicked="OnSaveClicked" />
                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>


        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
