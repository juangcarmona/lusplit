<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             xmlns:admob="clr-namespace:Plugin.MauiMtAdmob.Controls;assembly=Plugin.MauiMtAdmob"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             Title="{x:Static loc:AppResources.AddEvent_Title}">
    <Grid RowDefinitions="*,Auto,Auto" RowSpacing="0">
        <ScrollView>
            <VerticalStackLayout Padding="14,10,14,10" Spacing="8">
                <Label Text="{x:Static loc:AppResources.AddEvent_EventLabel}" Style="{StaticResource FieldLabel}" />
                <Entry Text="{Binding ExpenseTitle, Mode=TwoWay}"
                       Placeholder="{x:Static loc:AppResources.AddEvent_EventPlaceholder}" />
                <Label Text="{x:Static loc:AppResources.Validation_TitleRequired}"
                       Style="{StaticResource BodyMuted}"
                       TextColor="{StaticResource ErrorSoftRed}"
                       IsVisible="{Binding IsTitleInvalid}" />

                <Label Text="{x:Static loc:AppResources.Common_Amount}" Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Grid Grid.Column="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0">
                        <Label Grid.Column="0"
                               Text="{Binding CurrencyPrefix}"
                               FontSize="36"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryNavy}, Dark={StaticResource TextOnDark}}" />
                        <Entry x:Name="AmountEntry"
                               Grid.Column="1"
                               Text="{Binding AmountText, Mode=TwoWay}"
                               Keyboard="Numeric"
                               Placeholder="100"
                               FontSize="36" />
                        <Label Grid.Column="2"
                               Text="{Binding CurrencySuffix}"
                               FontSize="36"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimaryNavy}, Dark={StaticResource TextOnDark}}" />
                    </Grid>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="{x:Static loc:AppResources.AddEvent_IconLabel}" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding EventIconOptions}" SelectedItem="{Binding SelectedEventIconOption}" ItemDisplayBinding="{Binding DisplayText}" />
                    </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource StrokeLight}, Dark={StaticResource StrokeDark}}" />

                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="{x:Static loc:AppResources.AddEvent_PaidBy}" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName, Mode=TwoWay}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                            <Label Grid.Column="0" Text="📅" VerticalTextAlignment="Center" FontSize="16" />
                            <DatePicker Grid.Column="1" Date="{Binding ExpenseDate}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                            <Label Grid.Column="0" Text="🕐" VerticalTextAlignment="Center" FontSize="16" />
                            <TimePicker Grid.Column="1" Time="{Binding ExpenseTime}" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource StrokeLight}, Dark={StaticResource StrokeDark}}" />

                <Label Text="{x:Static loc:AppResources.AddEvent_WhoJoined}" Style="{StaticResource SectionTitle}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{x:Static loc:AppResources.AddEvent_SelectAll}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectAllCommand}"
                            Padding="6,4"
                            FontSize="12" />
                    <Button Grid.Column="1"
                            Text="{x:Static loc:AppResources.AddEvent_AdultsOnly}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding AdultsOnlyCommand}"
                            IsVisible="{Binding HasDependents}"
                            Padding="6,4"
                            FontSize="12" />
                </Grid>
                <CollectionView ItemsSource="{Binding ParticipantRows}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="1" Padding="0">
                                <Label Grid.Row="0"
                                       Text="{Binding GroupHeader}"
                                       Style="{StaticResource BodyMuted}"
                                       FontSize="11"
                                       IsVisible="{Binding HasGroupHeader}"
                                       Margin="0" />
                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                                    <CheckBox IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                              CheckedChanged="OnParticipantCheckChanged"
                                              Color="{StaticResource PositiveSoftGreen}"
                                              VerticalOptions="Center"
                                              MinimumWidthRequest="24"
                                              MinimumHeightRequest="24" />

                                    <Label Grid.Column="1"
                                           Text="{Binding Name}"
                                           
                                           FontSize="16"
                                           VerticalTextAlignment="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnParticipantRowTapped" CommandParameter="{Binding Id}" />
                                        </Label.GestureRecognizers>
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsIncluded}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Grid.Column="2"
                                           Text="{Binding DisplayValue}"                                           
                                           FontSize="16"
                                           VerticalTextAlignment="Center"
                                           HorizontalTextAlignment="End"
                                           IsVisible="{Binding IsViewing}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsIncluded}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Entry Grid.Column="2"
                                           Text="{Binding RawInput}"
                                           Keyboard="Numeric"
                                           HorizontalTextAlignment="End"
                                           FontSize="16"
                                           TextChanged="OnParticipantRawInputChanged"
                                           IsVisible="{Binding IsEditing}" />

                                    <Button Grid.Column="3"
                                            Text="{Binding ModeLabel}"
                                            Clicked="OnModeSelectorClicked"
                                            CommandParameter="{Binding Id}"
                                            Style="{StaticResource DropDownButton}"
                                            IsVisible="{Binding IsIncluded}"
                                            Padding="1,0"
                                            FontSize="16"
                                            MinimumWidthRequest="40"
                                            MinimumHeightRequest="26" />
                                </Grid>

                                <Label Grid.Row="2"
                                       Text="{Binding ValidationError}"
                                       Style="{StaticResource BodyMuted}"
                                       TextColor="{StaticResource ErrorSoftRed}"
                                       IsVisible="{Binding HasValidationError}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="{x:Static loc:AppResources.AddEvent_ImpactTitle}"
                       Style="{StaticResource SectionTitle}"
                       IsVisible="{Binding IsCalculationValid}" />
                <CollectionView ItemsSource="{Binding ImpactRows}"
                                SelectionMode="None"
                                HeightRequest="96"
                                IsVisible="{Binding IsCalculationValid}">
                    <CollectionView.EmptyView>
                        <Label Text="{x:Static loc:AppResources.AddEvent_ImpactHint}" Style="{StaticResource BodyMuted}" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{x:Static loc:AppResources.AddEvent_AttachMedia}"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnAttachMediaClicked" />
                    <Button Grid.Column="1"
                            Text="{x:Static loc:AppResources.AddEvent_TakePhoto}"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnTakePhotoClicked" />
                </Grid>

                <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                Padding="12,8"
                BackgroundColor="{AppThemeBinding Light={StaticResource BackgroundSnow}, Dark={StaticResource BackgroundDark}}"
                StrokeThickness="0">
            <Button Text="{x:Static loc:AppResources.AddEvent_SaveButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}" />
        </Border>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4">
            <admob:MTAdView
                x:Name="BottomBanner"
                HorizontalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
