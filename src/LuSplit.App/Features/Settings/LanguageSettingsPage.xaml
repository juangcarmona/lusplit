<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
             x:Class="LuSplit.App.Pages.LanguageSettingsPage"
             Title="{x:Static loc:AppResources.Settings_Title}">
    <Grid RowDefinitions="*,Auto" RowSpacing="0">
        <ScrollView>
            <VerticalStackLayout Padding="16,16,16,16" Spacing="10">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="{x:Static loc:AppResources.Settings_ProfileSection}"
                            Command="{Binding SelectProfileTabCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ShowProfileTab}" Value="False">
                                <Setter Property="Style" Value="{StaticResource SecondaryButton}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="1"
                            Text="{x:Static loc:AppResources.Settings_LanguageSection}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding SelectLanguageTabCommand}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding ShowLanguageTab}" Value="True">
                                <Setter Property="Style" Value="{x:Null}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>

                <VerticalStackLayout IsVisible="{Binding ShowProfileTab}" Spacing="10">
                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.Settings_MyNameLabel}" Style="{StaticResource FieldLabel}" />
                            <Entry Text="{Binding PreferredName}" Placeholder="{x:Static loc:AppResources.Settings_MyNamePlaceholder}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource FormFieldBorder}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{x:Static loc:AppResources.GroupDetails_CurrencyLabel}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding CurrencyOptions}"
                                    ItemDisplayBinding="{Binding DisplayLabel}"
                                    SelectedItem="{Binding SelectedCurrencyOption}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource FormFieldBorder}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Label Text="{x:Static loc:AppResources.Settings_ThemeLabel}" Style="{StaticResource BodyText}" VerticalTextAlignment="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsDarkThemeEnabled}" />
                        </Grid>
                    </Border>

                    <Button Text="{x:Static loc:AppResources.Settings_SaveProfileButton}"
                            Command="{Binding SaveProfileCommand}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding ShowLanguageTab}" Spacing="10">
                    <Label Text="{x:Static loc:AppResources.Settings_LanguageHint}" Style="{StaticResource BodyMuted}" />
                    <CollectionView ItemsSource="{Binding Languages}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ExpenseItemBorder}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <Label Text="{Binding DisplayLabel}" Style="{StaticResource BodyText}" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="✓"
                                               IsVisible="{Binding IsSelected}"
                                               Style="{StaticResource CardAmount}"
                                               TextColor="{StaticResource PanelLeftTeal}"
                                               HorizontalTextAlignment="End"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Tapped="OnLanguageTapped"
                                            CommandParameter="{Binding Culture}" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                HeightRequest="56"
                Padding="0,4" />
    </Grid>

</ContentPage>
