<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LuSplit.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:LuSplit.App.Pages"
    Title="LuSplit">

    <TabBar>
        <ShellContent
            Title="Trips"
            ContentTemplate="{DataTemplate pages:HomePage}"
            Route="trips" />
        <ShellContent
            Title="Activity"
            ContentTemplate="{DataTemplate pages:ActivityPage}"
            Route="activity" />
        <ShellContent
            Title="Balances"
            ContentTemplate="{DataTemplate pages:SettlementPage}"
            Route="balances" />
    </TabBar>

</Shell>
