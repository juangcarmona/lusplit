<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LuSplit.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:LuSplit.App.Pages"
    xmlns:loc="clr-namespace:LuSplit.App.Resources.Localization"
    Title="LuSplit"
    FlyoutBehavior="Flyout">

    <ShellContent
        Route="home"
        ContentTemplate="{DataTemplate pages:HomePage}"
        FlyoutItemIsVisible="False" />

    <FlyoutItem Title="{x:Static loc:AppResources.Groups_Title}" Route="groups">
        <ShellContent
            ContentTemplate="{DataTemplate pages:GroupSwitcherPage}"
            Route="group-switcher" />
    </FlyoutItem>

    <FlyoutItem Title="{x:Static loc:AppResources.Groups_ViewArchived}" Route="archived-groups-menu">
        <ShellContent
            ContentTemplate="{DataTemplate pages:ArchivedGroupsPage}"
            Route="archived-groups" />
    </FlyoutItem>

    <FlyoutItem Title="{x:Static loc:AppResources.Settings_Title}" Route="settings">
        <ShellContent
            ContentTemplate="{DataTemplate pages:LanguageSettingsPage}"
            Route="language-settings" />
    </FlyoutItem>

</Shell>
