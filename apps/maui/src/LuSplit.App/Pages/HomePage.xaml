<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.HomePage"
             Title="Home">
    <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding RefreshCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,24" Spacing="16">
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">
                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding GroupName}" Style="{StaticResource DisplayTitle}" />
                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding GroupSubtitle}" Style="{StaticResource BodyMuted}" />
                    <Border Grid.RowSpan="2" Grid.Column="1" Style="{StaticResource PillBorder}">
                        <Label Text="{Binding SummaryText}" Style="{StaticResource PillLabel}" />
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" Style="{StaticResource BalanceCardLeft}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Owes" Style="{StaticResource CardLabel}" />
                            <Label Text="{Binding OwesAmountText}" Style="{StaticResource AmountAmber}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource BalanceCardRight}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Settled" Style="{StaticResource CardLabel}" />
                            <Label Text="{Binding SettledAmountText}" Style="{StaticResource AmountGreen}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Label Text="Recent expenses" Style="{StaticResource SectionTitle}" />
                    <Label Grid.Column="1" Text="{Binding ExpenseCountText}" Style="{StaticResource BodyMuted}" />
                </Grid>

                <CollectionView ItemsSource="{Binding Expenses}">
                    <CollectionView.EmptyView>
                        <Label Text="No expenses yet. Add one to get started." Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ExpenseItemBorder}">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding Title}" Style="{StaticResource CardTitle}" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Amount}" Style="{StaticResource CardAmount}" />
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Meta}" Style="{StaticResource BodyMuted}" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding Payer}" Style="{StaticResource BodyMuted}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
