<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.AddExpensePage"
             Title="Add Expense">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
            <Label Text="Add expense" Style="{StaticResource DisplayTitle}" />
            <Label Text="Large fields, clear split, no finance jargon." Style="{StaticResource BodyMuted}" />

            <Border Style="{StaticResource FormFieldBorder}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Title" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding ExpenseTitle}" Placeholder="Dinner, groceries, ride..." ClearButtonVisibility="WhileEditing" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0" Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Amount (minor units)" Style="{StaticResource FieldLabel}" />
                        <Entry Text="{Binding AmountMinorText}" Keyboard="Numeric" Placeholder="e.g. 1250" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource FormFieldBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Date" Style="{StaticResource FieldLabel}" />
                        <DatePicker Date="{Binding ExpenseDate}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border Style="{StaticResource FormFieldBorder}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Paid by" Style="{StaticResource FieldLabel}" />
                    <Picker ItemsSource="{Binding PayerNames}" SelectedItem="{Binding SelectedPayerName}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Split people (equal default)" Style="{StaticResource SectionTitle}" />
            <FlexLayout Wrap="Wrap" Direction="Row" BindableLayout.ItemsSource="{Binding ParticipantOptions}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ChipBorder}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding Name}" VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Button Text="Save expense" Clicked="OnSaveClicked" />
            <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
