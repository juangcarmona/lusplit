<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.SettlementPage"
             Title="Settle">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
            <Label Text="Who owes what" Style="{StaticResource DisplayTitle}" />
            <Label Text="Clear resolution to avoid social tension." Style="{StaticResource BodyMuted}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="By participant" Clicked="OnParticipantModeClicked" />
                <Button Grid.Column="1" Text="By household owner" Clicked="OnOwnerModeClicked" />
            </Grid>

            <Label Text="Balances" Style="{StaticResource SectionTitle}" />
            <CollectionView ItemsSource="{Binding Balances}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding EntityId}" Style="{StaticResource CardTitle}" />
                                <Label Grid.Column="1" Text="{Binding Amount}" Style="{StaticResource CardAmount}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Settlement plan" Style="{StaticResource SectionTitle}" />
            <CollectionView ItemsSource="{Binding Transfers}">
                <CollectionView.EmptyView>
                    <Label Text="All settled." Style="{StaticResource BodyMuted}" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Label Text="{Binding Text}" Style="{StaticResource BodyText}" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
