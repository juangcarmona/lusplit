<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LuSplit.App.Pages.TripDetailsPage"
             Title="Trip details">
    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,24" Spacing="14">
            <Label Text="{Binding PageTitle}" Style="{StaticResource DisplayTitle}" />
            <Label Text="{Binding PageSubtitle}" Style="{StaticResource BodyMuted}" />

            <Border Style="{StaticResource FormFieldBorder}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Trip name" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding TripName}" Placeholder="Beach weekend, cabin stay..." ClearButtonVisibility="WhileEditing" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource FormFieldBorder}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Currency" Style="{StaticResource FieldLabel}" />
                    <Picker ItemsSource="{Binding CurrencyOptions}" SelectedItem="{Binding SelectedCurrency}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="People" Style="{StaticResource SectionTitle}" />
            <Label Text="Use the same household name when people should settle together." Style="{StaticResource BodyMuted}" />

            <CollectionView ItemsSource="{Binding People}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="0,8,0,0" Spacing="8">
                        <Label Text="No people yet." Style="{StaticResource SectionTitle}" HorizontalTextAlignment="Center" />
                        <Label Text="Add at least one person before saving the trip." Style="{StaticResource BodyMuted}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ExpenseItemBorder}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}" Style="{StaticResource CardTitle}" />
                                    <Label Text="{Binding HouseholdText}" Style="{StaticResource BodyMuted}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        IsVisible="{Binding CanRemove}"
                                        Text="Remove"
                                        Clicked="OnRemovePersonClicked"
                                        CommandParameter="{Binding Name}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Style="{StaticResource FormFieldBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Add person" Style="{StaticResource SectionTitle}" />
                    <Entry Text="{Binding NewPersonName}" Placeholder="Alex" ClearButtonVisibility="WhileEditing" />
                    <Entry Text="{Binding NewHouseholdName}" Placeholder="Household or family (optional)" ClearButtonVisibility="WhileEditing" />
                    <Button Text="Add person" Clicked="OnAddPersonClicked" />
                </VerticalStackLayout>
            </Border>

            <Button Text="{Binding SaveButtonText}" Clicked="OnSaveClicked" />
            <Label Text="{Binding StatusText}" Style="{StaticResource BodyMuted}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>